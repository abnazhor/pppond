<!DOCTYPE html>
<html>
  <head>
    <%= render 'layouts/head' %>
  </head>

  <body>
    <div class="relative container flex-1 shrink-0 items-center justify-center md:grid lg:max-w-none lg:grid-cols-2 lg:px-0">
      <div class="relative hidden h-full flex-col p-10 text-primary lg:flex dark:border-r">
        <div class="absolute inset-0 bg-primary/5"></div>
        <div class="relative z-20 flex items-center text-lg font-medium italic">
          ● pond
        </div>

        <div class="relative z-20 mt-auto">
          <blockquote class="leading-normal text-balance">Inverted social link aggregation or whatever</blockquote>
        </div>
      </div>

      <div class="flex items-center justify-center h-screen lg:p-8">
        <div class="mx-auto flex w-full flex-col justify-center gap-6 sm:w-[350px]">
          <%= yield %>
        </div>
      </div>
    </div>

    <%= render RubyUI::ToastRegion.new(flash: flash.to_h) %>
  </body>
</html>
