<% if @pin.errors.any? %>
  <turbo-stream action="toast" target="ruby-ui-toaster" variant="error" title="Error" description="<%= @pin.errors.full_messages&.to_sentence %>">
    <template></template>
  </turbo-stream>
<% else %>
  <turbo-stream action="toast" target="ruby-ui-toaster" variant="success" title="All good!" description="Pin connected to <%= @pin.collection.name %>">
    <template></template>
  </turbo-stream>

  <turbo-stream action="close_dialog" target="connect-dialog">
    <template></template>
  </turbo-stream>

  <% if @referrer_action[:controller] == "collections" && @referrer_action[:action] == "index" %>
    <turbo-stream action="update" target="<%= dom_id(@pin.collection) %>">
      <template>
        <%= render Components::Collections::Collection.new(collection: @pin.collection) %>
      </template>
    </turbo-stream>
  <% end %>
<% end %>
